  version                  = "3.1.0"
  limits                   = var.limits
  bucket_name              = var.bucket_name
  additional_project_roles = var.additional_project_roles
  slo_configs              = var.slo_configs
  region                   = var.region
  concurrency              = var.concurrency
  secrets                  = var.secrets
  pubsub_topic_name        = var.pubsub_topic_name
