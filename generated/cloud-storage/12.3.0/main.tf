  hierarchical_namespace   = var.hierarchical_namespace
  viewers                  = var.viewers
  labels                   = var.labels
  set_creator_roles        = var.set_creator_roles
  cors                     = var.cors
  soft_delete_policy       = var.soft_delete_policy
  ip_filter                = var.ip_filter
  project_id               = var.project_id
  location                 = var.location
}
